# bootlab-pxe configuration
# Copy to .env and edit before running docker compose up

# === Network (REQUIRED) ===
# This machine's LAN IP — gaming PCs must be able to reach it
PXE_SERVER=192.168.0.222

# Primary LAN network interface
LAN_INTERFACE=eth0

# LAN subnet for DHCP proxy
LAN_SUBNET=192.168.0.0/24

# === Ports (defaults usually fine) ===
PXE_HTTP_PORT=8085
PANEL_PORT=3006

# === Database ===
POSTGRES_PASSWORD=changeme

# === Cloudflare Access (optional — leave empty to disable) ===
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
